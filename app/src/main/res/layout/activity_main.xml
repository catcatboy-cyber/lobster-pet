<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/white">

    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_lobster"
        android:contentDescription="@string/app_name"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/lobster_red"
        app:layout_constraintTop_toBottomOf="@id/ivLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tvDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="点击龙虾说出指令：「打开微信」「发送你好」「退下」"
        android:textSize="14sp"
        android:textColor="@color/gray"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStart"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="召唤龙虾"
        android:textSize="16sp"
        app:cornerRadius="28dp"
        android:backgroundTint="@color/lobster_red"
        app:layout_constraintBottom_toTopOf="@id/btnAccessibility"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp"
        android:layout_marginHorizontal="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAccessibility"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="开启辅助功能（自动输入文字）"
        android:textSize="14sp"
        app:cornerRadius="28dp"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:textColor="@color/lobster_red"
        app:strokeColor="@color/lobster_red"
        app:layout_constraintBottom_toTopOf="@id/btnAIChat"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp"
        android:layout_marginHorizontal="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAIChat"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="🤖 AI 代聊管理"
        android:textSize="14sp"
        app:cornerRadius="28dp"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:textColor="@color/lobster_red"
        app:strokeColor="@color/lobster_red"
        app:layout_constraintBottom_toTopOf="@id/btnStop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp"
        android:layout_marginHorizontal="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStop"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="让龙虾退下"
        android:textSize="16sp"
        app:cornerRadius="28dp"
        style="@style/Widget.Material3.Button.TextButton"
        android:textColor="@color/gray"
        app:layout_constraintBottom_toTopOf="@id/btnUpdate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp"
        android:layout_marginHorizontal="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUpdate"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="🔄 检查更新"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="28dp"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:textColor="@color/lobster_red"
        app:strokeColor="@color/lobster_red"
        app:strokeWidth="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp"
        android:layout_marginHorizontal="32dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
